{
  "name": "@threadify/sdk",
  "version": "0.1.10",
  "description": "JavaScript SDK for Threadify - Execute business process graphs with context—track what happened, validate every step, and trigger context-aware actions",
  "main": "dist/index.cjs",
  "module": "src/index.js",
  "type": "module",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./src/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "node scripts/build-cjs.js",
    "test": "echo \"Warning: No tests configured for production build\" && exit 0",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules npx jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules npx jest --watch",
    "prepublishOnly": "npm run build && npm test",
    "publish:dry": "npm pack --dry-run",
    "publish:beta": "npm publish --tag beta"
  },
  "keywords": [
    "workflow",
    "orchestration",
    "state-machine",
    "business-process",
    "event-driven",
    "audit-trail",
    "saga-pattern",
    "distributed-transactions",
    "websocket",
    "real-time-notifications",
    "validation",
    "contract-enforcement",
    "idempotency",
    "retry-logic",
    "thread-management"
  ],
  "author": "Threadify Team",
  "license": "MIT",
  "dependencies": {
    "ws": "^8.14.2"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "src/",
    "dist/",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/intelijence/threadify-engine",
    "directory": "threadify-sdk"
  },
  "homepage": "https://github.com/intelijence/threadify-engine/tree/main/threadify-sdk"
}
