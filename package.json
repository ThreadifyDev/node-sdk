{
  "name": "@threadify/sdk",
  "version": "0.1.24",
  "description": "JavaScript SDK for Threadify - Execute business process graphs with context—track what happened, validate every step, and trigger context-aware actions",
  "main": "dist/index.cjs",
  "module": "src/index.js",
  "type": "module",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./src/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "node scripts/build-cjs.js",
    "test": "echo \"Warning: No tests configured for production build\" && exit 0",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules npx jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules npx jest --watch",
    "prepublishOnly": "npm run build && npm test",
    "publish:dry": "npm pack --dry-run",
    "publish:beta": "npm publish --tag beta"
  },
  "keywords": [
    "service-delivery",
    "workflow-cordination",
    "business-process",
    "threadify",
    "threadify.dev",
    "threadify-dev",
    "distributed tracing",
    "service-delivery-intelligence"
  ],
  "author": "Threadify Team",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.7.0",
    "ws": "^8.14.2"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "src/",
    "dist/",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ThreadifyDev/node-sdk.git",
    "directory": "threadify-sdk"
  },
  "homepage": "https://github.com/ThreadifyDev/node-sdk"
}